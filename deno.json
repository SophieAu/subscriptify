{
  "nodeModulesDir": "auto",
  "exclude": ["web"],
  "tasks": {
    "dev": "deno run -A --env-file=.env.local --watch server/main.ts",
    "dev:web": "cd web && deno run -A npm:astro dev",
    "build:web": "cd web && deno install && deno run -A npm:astro build",
    "db:generate": "deno run -A npm:prisma generate",
    "db:push": "deno run -A --env-file=.env.local npm:prisma db push",
    "db:seed": "deno run -A --env-file=.env.local prisma/seed.ts",
    "check": "deno check server/main.ts prisma/seed.ts",
    "test": "deno test --env-file=.env.test --allow-env server/"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "hono": "npm:hono@^4.12.0",
    "hono/": "npm:/hono@^4.12.0/",
    "@clerk/backend": "npm:@clerk/backend@^3",
    "@prisma/client": "npm:@prisma/client@^7",
    "@prisma/adapter-neon": "npm:@prisma/adapter-neon@^7",
    "prisma": "npm:prisma@^7"
  }
}
