# Copy to .env.local and fill in. Astro picks up PUBLIC_* vars from here too (envDir points at repo root).

# Neon Postgres connection string
DATABASE_URL=
DIRECT_URL=

# Clerk (Spotify configured as social connection in the Clerk dashboard)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
PUBLIC_CLERK_PUBLISHABLE_KEY=
PUBLIC_CLERK_SIGN_IN_URL=/sign-in
PUBLIC_CLERK_SIGN_UP_URL=/sign-up